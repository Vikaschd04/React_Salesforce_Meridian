# Meridian BFF configuration. Copy to .env and fill in.
# .env is git-ignored — never commit real secrets.

# ---- Server ----
# Port the BFF listens on (Vite dev proxy points here — see vite.config.js).
PORT=8787

# Origin allowed by CORS. Must match where the front end is served in dev.
APP_ORIGIN=http://localhost:5173

# Product read cache time-to-live, in seconds.
CACHE_TTL_SECONDS=60

# ---- Data source ----
# 'mock' (default) uses the in-repo catalog. 'salesforce' uses a live org
# (requires the SF_* values below). Flip to 'salesforce' once setup is done.
DATA_SOURCE=mock

# ---- Salesforce (used only when DATA_SOURCE=salesforce) ----
# Client Credentials OAuth flow. See docs/SALESFORCE_SETUP.md for how to obtain these.
# Sandbox logs in at test.salesforce.com; Developer Edition/production at login.salesforce.com.
SF_LOGIN_URL=https://test.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# REST/SOQL API version used for queries + composite writes.
SF_API_VERSION=61.0
# Account that guest web orders are attached to (created during setup).
SF_ACCOUNT_NAME=Meridian Web Orders

# ---- Shopper sessions (login/signup) ----
# Secret used to sign the httpOnly session JWT. Use a long random string in prod.
SESSION_SECRET=change-me-to-a-long-random-string
# How long a session lasts.
SESSION_TTL_DAYS=30
# Set true only when serving over HTTPS (production).
COOKIE_SECURE=false
